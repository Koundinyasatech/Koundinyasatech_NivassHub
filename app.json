{
  "expo": {
    "name": "NivassHub",
    "slug": "nivasshub",
    "version": "1.0.0",
    "scheme": "nivasshub",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.nivasshub.app",
      "newArchEnabled": false
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
